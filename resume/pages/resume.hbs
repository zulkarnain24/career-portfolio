{{> Header}}
<main class="rp-main">
  <div class="container">
    {{#each sections}}
      <section id="{{id}}" class="section section-{{@index}}">
        {{#if title}}<h2>{{title}}</h2>{{/if}}
        <div class="section-body">{{{html}}}</div>
      </section>
    {{/each}}

    {{> Timeline}}

    {{#if projects}}
      <section class="projects">
        <h2>Projects</h2>
        <div class="projects-grid">
          {{#each projects}}
            {{> ProjectCard}}
          {{/each}}
        </div>
      </section>
    {{/if}}
  </div>
</main>

{{> Footer}}
